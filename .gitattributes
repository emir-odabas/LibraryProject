# Set default behavior to automatically normalize line endings.
* text=auto

# C# files
*.cs     diff=csharp text

# MSBuild and project files
*.sln       merge=binary
*.csproj    merge=binary
*.vbproj    merge=binary
*.vcxproj   merge=binary
*.vcproj    merge=binary
*.dbproj    merge=binary
*.fsproj    merge=binary
*.lsproj    merge=binary
*.wixproj   merge=binary
*.modelproj merge=binary
*.sqlproj   merge=binary
*.wwaproj   merge=binary

# Image files are treated as binary by default.
*.jpg   binary
*.png   binary
*.gif   binary

# Markdown
*.md    text

# Config files
*.json  text
*.config text
*.xml   text
